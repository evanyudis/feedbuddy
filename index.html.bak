<!DOCTYPE html>
<html lang="id" data-theme="light" data-gender="girl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
  <title>Bumpbuddy</title>
  <meta name="description" content="Pendamping kehamilan — catat kontraksi, gerakan bayi, siapkan tas RS.">

  <!-- PWA -->
  <link rel="manifest" href="manifest.json">
  <meta name="theme-color" content="#F7F3F5" media="(prefers-color-scheme: light)">
  <meta name="theme-color" content="#1B1B1E" media="(prefers-color-scheme: dark)">
  <link rel="apple-touch-icon" href="img/app-icon.jpg">
  <link rel="icon" type="image/jpeg" href="img/app-icon.jpg">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="default">
  <meta name="apple-mobile-web-app-title" content="Bumpbuddy">

  <!-- Geist — SwiftUI-inspired type -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700;800;900&family=Geist+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="style.css">

  <!-- PostHog Analytics -->
  <script>
    !function(t,e){var o,n,p,r;e.__SV||(window.posthog=e,e._i=[],e.init=function(i,s,a){function g(t,e){var o=e.split(".");2==o.length&&(t=t[o[0]],e=o[1]),t[e]=function(){t.push([e].concat(Array.prototype.slice.call(arguments,0)))}}(p=t.createElement("script")).type="text/javascript",p.async=!0,p.src=s.api_host.replace(".i.posthog.com","-assets.i.posthog.com")+"/static/array.js",(r=t.getElementsByTagName("script")[0]).parentNode.insertBefore(p,r);var u=e;for(void 0!==a?u=e[a]=[]:a="posthog",u.people=u.people||[],u.toString=function(t){var e="posthog";return"posthog"!==a&&(e+="."+a),t||(e+=" (stub)"),e},u.people.toString=function(){return u.toString(1)+".people (stub)"},o="init capture register register_once register_for_session unregister unregister_for_session getFeatureFlag getFeatureFlagPayload isFeatureEnabled reloadFeatureFlags updateEarlyAccessFeatureEnrollment getEarlyAccessFeatures on onFeatureFlags onSessionId getSurveys getActiveMatchingSurveys renderSurvey canRenderSurvey getNextSurveyStep identify setPersonProperties group reset groups setPersonPropertiesForFlags resetPersonPropertiesForFlags setGroupPropertiesForFlags resetGroupPropertiesForFlags resetGroups set_config startSessionRecording stopSessionRecording sessionRecordingStarted captureException loadToolbar get_property getSessionProperty createPersonProfile opt_in_capturing opt_out_capturing has_opted_in_capturing has_opted_out_capturing clear_opt_in_out_capturing debug getPageViewId captureTrace feedback get_session_id".split(" "),n=0;n<o.length;n++)g(u,o[n]);e._i.push([i,s,a])},e.__SV=1)}(document,window.posthog||[]);
    posthog.init('phc_nkUQyfmHXrDRUjK8Y4AWqUoLk7Nx9KnKzWgSCLrsjfW5', {
      api_host: 'https://us.i.posthog.com',
      person_profiles: 'always' 
    })
  </script>
</head>
<body>
<div id="app">
  <div class="noise-overlay"></div>

  <!-- HEADER -->
  <header id="app-header">
    <div class="header-inner">
      <div class="logo">
        <span class="logo-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
        </span>
        <span class="logo-text">Baby <span id="ui-baby-name">Baby</span>'s Mom Buddy</span>
      </div>
    </div>
  </header>

  <!-- HERO / COUNTDOWN -->
  <section class="hero-section" id="countdown-hero">
    <p class="hero-label">Hari Perkiraan Lahir</p>
    <h1 class="hero-date" id="hero-date-display">14 April 2026</h1>
    <div class="countdown-grid" id="countdown-grid">
      <div class="countdown-item">
        <span class="countdown-value" id="cd-days">--</span>
        <span class="countdown-unit">Hari</span>
      </div>
      <div class="countdown-sep">:</div>
      <div class="countdown-item">
        <span class="countdown-value" id="cd-hours">--</span>
        <span class="countdown-unit">Jam</span>
      </div>
      <div class="countdown-sep">:</div>
      <div class="countdown-item">
        <span class="countdown-value" id="cd-minutes">--</span>
        <span class="countdown-unit">Menit</span>
      </div>
      <div class="countdown-sep">:</div>
      <div class="countdown-item">
        <span class="countdown-value" id="cd-seconds">--</span>
        <span class="countdown-unit">Detik</span>
      </div>
    </div>
    <div class="hero-week" id="hero-week"></div>
  </section>

  <!-- TAB PANELS -->
  <main id="tab-panels">

    <!-- CONTRACTIONS -->
    <section id="panel-contractions" class="panel active">

      <div id="labor-alert-warning" class="alert-banner alert-warning hidden" role="alert">
        <div class="alert-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        </div>
        <div class="alert-content">
          <strong id="alert-warning-title">Perhatian</strong>
          <p id="alert-warning-desc">Kontraksi mulai sering. Terus pantau dan siapkan diri ke RS.</p>
        </div>
        <button class="btn-alert-dismiss" id="btn-dismiss-warning" aria-label="Tutup">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>

      <div class="timer-card">
        <h2 class="section-title">Timer Kontraksi</h2>
        <p class="timer-subtitle" id="timer-subtitle">Tekan mulai saat kontraksi dimulai</p>
        <div class="timer-display" id="timer-display">00:00</div>
        <div class="timer-controls">
          <button id="btn-contraction-toggle" class="btn btn-primary btn-primary pulse-anim" aria-live="polite">
            <span id="btn-contraction-text">MULAI</span>
          </button>
          <button id="btn-contraction-reset" class="btn btn-ghost" style="display:none;">Reset</button>
        </div>
        <div id="intensity-picker" class="intensity-picker hidden">
          <p class="picker-label">Intensitas kontraksi:</p>
          <div class="intensity-btns">
            <button class="intensity-btn" data-val="ringan">Ringan</button>
            <button class="intensity-btn selected" data-val="sedang">Sedang</button>
            <button class="intensity-btn" data-val="kuat">Kuat</button>
          </div>
        </div>
      </div>

      <div id="contraction-stats" class="stats-row hidden">
        <div class="stat-card">
          <span class="stat-value" id="stat-avg-duration">--</span>
          <span class="stat-label">Rata-rata Durasi</span>
        </div>
        <div class="stat-card">
          <span class="stat-value" id="stat-avg-interval">--</span>
          <span class="stat-label">Rata-rata Jarak</span>
        </div>
        <div class="stat-card">
          <span class="stat-value teal" id="stat-count">0</span>
          <span class="stat-label">Total</span>
        </div>
      </div>

      <div class="panel-section">
        <div class="row-header">
          <h3>Riwayat Kontraksi</h3>
          <button id="btn-clear-contractions" class="btn btn-ghost btn-sm">Hapus Semua</button>
        </div>
        <div id="contraction-log" class="log-list">
          <div class="empty-state">
            <div class="empty-state-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <div class="empty-state-title">Belum ada kontraksi</div>
            <div class="empty-state-desc">Tekan MULAI saat kamu mulai merasakan kontraksi pertama.</div>
          </div>
        </div>
      </div>
    </section>

    <!-- BABY MOVEMENTS -->
    <section id="panel-movements" class="panel">
      <div class="movement-card">
        <h2 class="section-title">Gerakan Bayi</h2>
        <div class="kick-counter-wrap">
          <span class="kick-count" id="kick-count">0</span>
          <span class="kick-label">tendangan / gerakan hari ini</span>
        </div>
        <div class="kick-goal-bar-wrap">
          <div class="kick-goal-bar-label">Target: 10 gerakan</div>
          <div class="kick-goal-bar">
            <div class="kick-goal-fill" id="kick-goal-fill" style="width: 0%"></div>
          </div>
        </div>
        <div class="kick-actions">
          <button id="btn-undo-kick" class="btn btn-icon" title="Batal catat" aria-label="Batal">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 14 4 9 9 4"/><path d="M20 20v-7a4 4 0 0 0-4-4H4"/></svg>
          </button>
          <button id="btn-kick" class="kick-btn" aria-label="Catat gerakan bayi">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12h.01"/><path d="M15 12h.01"/><path d="M10 16c.5.3 1.2.5 2 .5s1.5-.2 2-.5"/><path d="M19 6.3a9 9 0 0 1 1.8 3.9 2 2 0 0 1 0 3.6 9 9 0 0 1-17.6 0 2 2 0 0 1 0-3.6A9 9 0 0 1 12 3c2 0 3.5 1.1 3.5 2.5s-.9 2.5-2 2.5c-.8 0-1.5-.4-1.5-1"/></svg>
          </button>
          <div style="width:38px;"></div>
        </div>
        <p class="kick-hint" id="kick-hint-text">10 gerakan per sesi 2 jam adalah normal</p>
      </div>

      <div class="stats-row two-col">
        <div class="stat-card">
          <span class="stat-value teal" id="stat-kicks-today">0</span>
          <span class="stat-label">Hari Ini</span>
        </div>
        <div class="stat-card">
          <span class="stat-value" id="stat-kicks-week">0</span>
          <span class="stat-label">Minggu Ini</span>
        </div>
      </div>

      <div class="panel-section">
        <div class="row-header">
          <h3>Riwayat Gerakan</h3>
          <button id="btn-clear-movements" class="btn btn-ghost btn-sm">Hapus Semua</button>
        </div>
        <div id="movement-log" class="log-list">
          <div class="empty-state">
            <div class="empty-state-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 3s-1 1-1 4a12 12 0 0 0 12 12c3 0 4-1 4-4s-1-4-1-4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="M22 12h-2"/><path d="M4 12H2"/><path d="M19 19l-1-1"/><path d="M6 6L5 5"/><path d="M19 5l-1 1"/><path d="M6 18l-1 1"/></svg>
            </div>
            <div class="empty-state-title">Pantau gerakan bayi</div>
            <div class="empty-state-desc">Ketuk tombol tendangan setiap kali kamu merasa si kecil bergerak.</div>
          </div>
        </div>
      </div>
    </section>

    <!-- SYMPTOMS -->
    <section id="panel-symptoms" class="panel">
      <div class="timer-card" style="padding: var(--sp-6);">
        <h2 class="section-title">Catat Gejala</h2>
        <p class="section-subtitle">Ketuk gejala yang kamu rasakan</p>
        <div class="bento-grid" id="symptom-grid">
          <!-- Row 1 -->
          <button class="symptom-btn" data-symptom="Mual">
            <span class="symptom-btn-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><circle cx="12" cy="11" r="3"/><path d="M12 16v.01"/></svg></span>Mual
          </button>
          <button class="symptom-btn" data-symptom="Pusing">
            <span class="symptom-btn-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12a10 10 0 1020 0 10 10 0 00-20 0"/><path d="M8 12c1.5-1.5 3-1.5 4 0s2.5 1.5 4 0"/><path d="M12 8v8"/></svg></span>Pusing
          </button>
          <!-- Row 2 -->
          <button class="symptom-btn" data-symptom="Nyeri Punggung">
            <span class="symptom-btn-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v18"/><path d="M8 8h8"/><path d="M8 12h8"/><path d="M8 16h8"/></svg></span>Nyeri Punggung
          </button>
          <button class="symptom-btn" data-symptom="Kram Perut">
            <span class="symptom-btn-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 12c1.5 1.5 3 1.5 4 0s2.5-1.5 4 0"/></svg></span>Kram Perut
          </button>
          <!-- Row 3 -->
          <button class="symptom-btn" data-symptom="Bengkak">
            <span class="symptom-btn-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg></span>Bengkak
          </button>
          <button class="symptom-btn" data-symptom="Sakit Kepala">
            <span class="symptom-btn-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 100 20 10 10 0 000-20z"/><path d="M13 14l-2 2-2-2 2-2 2-2 2 2z"/></svg></span>Sakit Kepala
          </button>
          <!-- Row 4 -->
          <button class="symptom-btn" data-symptom="Kelelahan">
            <span class="symptom-btn-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="16" height="10" rx="2" ry="2"/><line x1="22" y1="11" x2="22" y2="13"/><line x1="6" y1="12" x2="6" y2="12"/></svg></span>Kelelahan
          </button>
          <button class="symptom-btn" data-symptom="Insomnia">
            <span class="symptom-btn-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/></svg></span>Insomnia
          </button>
          <!-- Row 5 -->
          <button class="symptom-btn" data-symptom="Heartburn">
            <span class="symptom-btn-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2c0 0-5 6-5 10a5 5 0 1010 0c0-4-5-10-5-10z"/></svg></span>Heartburn
          </button>
          <button class="symptom-btn" data-symptom="Sesak Napas">
            <span class="symptom-btn-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M9.59 4.59A2 2 0 1111 8H2m10.59 11.41A2 2 0 1014 16H2m15.73-8.27A2.5 2.5 0 1119.5 12H2"/></svg></span>Sesak Napas
          </button>
          <!-- Row 6 -->
          <button class="symptom-btn" data-symptom="Sering BAK">
            <span class="symptom-btn-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22a7 7 0 007-7c0-2-1-3.9-3-5.5s-3.5-4-4-6.5c-.5 2.5-2 4.9-4 6.5C6 11.1 5 13 5 15a7 7 0 007 7z"/></svg></span>Sering BAK
          </button>
          <button class="symptom-btn" data-symptom="Mood Swing">
            <span class="symptom-btn-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><path d="M9 9h.01"/><path d="M15 9h.01"/></svg></span>Mood Swing
          </button>
        </div>
      </div>

      <div class="panel-section">
        <div class="row-header">
          <h3>Riwayat Gejala</h3>
          <button id="btn-clear-symptoms" class="btn btn-ghost btn-sm">Hapus Semua</button>
        </div>
        <div id="symptom-log" class="log-list">
          <div class="empty-state">
            <div class="empty-state-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
            </div>
            <div class="empty-state-title">Riwayat gejala kosong</div>
            <div class="empty-state-desc">Catatan gejala akan muncul di sini untuk memudahkan konsultasi dokter.</div>
          </div>
        </div>
      </div>
    </section>

    <!-- HOSPITAL BAG -->
    <section id="panel-bag" class="panel">
      <div class="bag-progress-section">
        <div class="bag-progress-label">
          <span class="bag-progress-label-text">Kesiapan Tas RS</span>
          <span class="bag-progress-text" id="bag-progress-text">0%</span>
        </div>
        <div class="bag-progress-bar">
          <div class="bag-progress-fill" id="bag-progress-fill" style="width:0%"></div>
        </div>
      </div>

      <div id="bag-checklist">
        <div class="bag-category">
          <h3 class="bag-cat-title" data-toggle="cat-dokumen">
            <span>Dokumen Penting</span>
            <span class="bag-cat-right">
              <span class="bag-cat-count" id="count-dokumen">0/5</span>
              <span class="chevron">&#8964;</span>
            </span>
          </h3>
          <ul class="bag-items" id="cat-dokumen">
            <li><label><input type="checkbox" data-bag="ktp"> KTP / Kartu Identitas</label></li>
            <li><label><input type="checkbox" data-bag="bpjs"> Kartu BPJS / Asuransi</label></li>
            <li><label><input type="checkbox" data-bag="buku-kia"> Buku KIA / Prenatal</label></li>
            <li><label><input type="checkbox" data-bag="hasil-lab"> Hasil Lab &amp; USG</label></li>
            <li><label><input type="checkbox" data-bag="surat-nikah"> Surat Nikah (fotokopi)</label></li>
          </ul>
        </div>

        <div class="bag-category">
          <h3 class="bag-cat-title" data-toggle="cat-ibu">
            <span>Keperluan Ibu</span>
            <span class="bag-cat-right">
              <span class="bag-cat-count" id="count-ibu">0/9</span>
              <span class="chevron">&#8964;</span>
            </span>
          </h3>
          <ul class="bag-items" id="cat-ibu">
            <li><label><input type="checkbox" data-bag="baju-ganti"> Baju Ganti (2-3 set)</label></li>
            <li><label><input type="checkbox" data-bag="daster"> Daster / Baju Menyusui</label></li>
            <li><label><input type="checkbox" data-bag="cd"> Celana Dalam Sekali Pakai</label></li>
            <li><label><input type="checkbox" data-bag="pembalut"> Pembalut Nifas</label></li>
            <li><label><input type="checkbox" data-bag="toiletries"> Peralatan Mandi</label></li>
            <li><label><input type="checkbox" data-bag="sandal"> Sandal</label></li>
            <li><label><input type="checkbox" data-bag="breast-pad"> Breast Pad</label></li>
            <li><label><input type="checkbox" data-bag="snack"> Snack &amp; Minuman</label></li>
            <li><label><input type="checkbox" data-bag="charger"> Charger HP</label></li>
          </ul>
        </div>

        <div class="bag-category">
          <h3 class="bag-cat-title" data-toggle="cat-bayi">
            <span>Keperluan Bayi</span>
            <span class="bag-cat-right">
              <span class="bag-cat-count" id="count-bayi">0/7</span>
              <span class="chevron">&#8964;</span>
            </span>
          </h3>
          <ul class="bag-items" id="cat-bayi">
            <li><label><input type="checkbox" data-bag="baju-bayi"> Baju Bayi (3-4 set)</label></li>
            <li><label><input type="checkbox" data-bag="popok"> Popok Newborn</label></li>
            <li><label><input type="checkbox" data-bag="topi"> Topi Bayi</label></li>
            <li><label><input type="checkbox" data-bag="sarung-tangan"> Sarung Tangan &amp; Kaki</label></li>
            <li><label><input type="checkbox" data-bag="selimut"> Selimut / Bedong</label></li>
            <li><label><input type="checkbox" data-bag="washlap"> Washlap</label></li>
            <li><label><input type="checkbox" data-bag="minyak-telon"> Minyak Telon</label></li>
          </ul>
        </div>

        <div class="bag-category">
          <h3 class="bag-cat-title" data-toggle="cat-pendamping">
            <span>Keperluan Pendamping</span>
            <span class="bag-cat-right">
              <span class="bag-cat-count" id="count-pendamping">0/4</span>
              <span class="chevron">&#8964;</span>
            </span>
          </h3>
          <ul class="bag-items" id="cat-pendamping">
            <li><label><input type="checkbox" data-bag="baju-pendamping"> Baju Ganti</label></li>
            <li><label><input type="checkbox" data-bag="snack-p"> Snack &amp; Minuman</label></li>
            <li><label><input type="checkbox" data-bag="uang"> Uang Tunai</label></li>
            <li><label><input type="checkbox" data-bag="kamera"> Kamera / HP</label></li>
          </ul>
        </div>
      </div>
    </section>

    <!-- SETTINGS -->
    <section id="panel-settings" class="panel">
      <div style="padding: var(--sp-2) 0 var(--sp-8);">

        <div class="settings-section">
          <p class="settings-section-label">Informasi Kehamilan</p>
          <div class="settings-list">
            <div class="settings-row">
              <span class="settings-row-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg></span>
              <div class="settings-row-body"><div class="settings-row-label">Hari Perkiraan Lahir</div></div>
              <div class="settings-row-control">
                <input type="date" id="setting-due-date" class="settings-input" value="2026-04-14">
              </div>
            </div>
            <div class="settings-row">
              <span class="settings-row-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></span>
              <div class="settings-row-body"><div class="settings-row-label">Nama Ibu</div></div>
              <div class="settings-row-control">
                <input type="text" id="setting-name" class="settings-input" placeholder="Nama...">
              </div>
            </div>
            <div class="settings-row">
              <span class="settings-row-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12h.01"/><path d="M15 12h.01"/><path d="M10 16c.5.3 1.2.5 2 .5s1.5-.2 2-.5"/><path d="M19 6.3a9 9 0 0 1 1.8 3.9 2 2 0 0 1 0 3.6 9 9 0 0 1-17.6 0 2 2 0 0 1 0-3.6A9 9 0 0 1 12 3c2 0 3.5 1.1 3.5 2.5s-.9 2.5-2 2.5c-.8 0-1.5-.4-1.5-1"/></svg></span>
              <div class="settings-row-body"><div class="settings-row-label">Nama Bayi</div></div>
              <div class="settings-row-control">
                <input type="text" id="setting-baby-name" class="settings-input" placeholder="Panggilan Bayi...">
              </div>
            </div>
            <div class="settings-row">
              <span class="settings-row-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg></span>
              <div class="settings-row-body"><div class="settings-row-label">Gender Bayi</div></div>
              <div class="settings-row-control">
                <select id="setting-gender" class="settings-input" style="appearance:none;-webkit-appearance:none;cursor:pointer;text-align:right;">
                  <option value="girl">Perempuan</option>
                  <option value="boy">Laki-laki</option>
                </select>
              </div>
            </div>
          </div>
        </div>

        <div class="settings-section">
          <p class="settings-section-label">Tampilan</p>
          <div class="settings-list">
            <div class="settings-row" style="flex-wrap: wrap;">
              <div style="display: flex; align-items: center; width: 100%; gap: var(--sp-3);">
                <span class="settings-row-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg></span>
                <div class="settings-row-body" style="flex: 1;">
                  <div class="settings-row-label">Tampilan Aplikasi</div>
                  <div class="settings-row-desc">Pilih tema warna</div>
                </div>
              </div>
              <div class="segmented-control" id="theme-switcher" style="width: 100%; margin-top: var(--sp-3);">
                <button class="segment-btn active" data-theme-val="light">Terang</button>
                <button class="segment-btn" data-theme-val="dark">Gelap</button>
                <button class="segment-btn" data-theme-val="system">Sistem</button>
              </div>
            </div>
          </div>
        </div>

        <div class="settings-section">
          <p class="settings-section-label">Kontak Darurat</p>
          <div class="settings-list">
            <div class="settings-row">
              <span class="settings-row-icon" style="background: var(--danger-light); color: var(--danger);"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.09 9.81a19.79 19.79 0 01-3.07-8.67A2 2 0 012 .84h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.91 8.84a16 16 0 006.29 6.29l1.28-1.28a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7a2 2 0 011.72 2.02z"/></svg></span>
              <div class="settings-row-body"><div class="settings-row-label">Ambulans</div></div>
              <div class="settings-row-control">
                <input type="tel" class="settings-input" value="119" readonly style="color: var(--danger); font-weight: 700;">
              </div>
            </div>
            <div class="settings-row">
              <span class="settings-row-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg></span>
              <div class="settings-row-body"><div class="settings-row-label">Suami / Pendamping</div></div>
              <div class="settings-row-control">
                <input type="tel" id="setting-partner-phone" class="settings-input" placeholder="Nomor HP...">
              </div>
            </div>
            <div class="settings-row">
              <span class="settings-row-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="16" y1="11" x2="22" y2="11"/></svg></span>
              <div class="settings-row-body"><div class="settings-row-label">Dokter Kandungan</div></div>
              <div class="settings-row-control">
                <input type="tel" id="setting-doctor-phone" class="settings-input" placeholder="Nomor HP...">
              </div>
            </div>
          </div>
        </div>

        <div class="settings-section">
          <p class="settings-section-label">Informasi Rumah Sakit</p>
          <div class="settings-list">
            <div class="settings-row">
              <span class="settings-row-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg></span>
              <div class="settings-row-body"><div class="settings-row-label">Nama RS</div></div>
              <div class="settings-row-control">
                <input type="text" id="setting-hospital-name" class="settings-input" placeholder="Nama RS...">
              </div>
            </div>
            <div class="settings-row">
              <span class="settings-row-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.09 9.81a19.79 19.79 0 01-3.07-8.67A2 2 0 012 .84h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.91 8.84a16 16 0 006.29 6.29l1.28-1.28a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7a2 2 0 011.72 2.02z"/></svg></span>
              <div class="settings-row-body"><div class="settings-row-label">Telepon RS</div></div>
              <div class="settings-row-control">
                <input type="tel" id="setting-hospital-phone" class="settings-input" placeholder="Nomor RS...">
              </div>
            </div>
          </div>
        </div>

        <div class="settings-section">
          <p class="settings-section-label">Aplikasi</p>
          <div class="settings-list">
            <div class="settings-row" style="align-items: flex-start;">
              <span class="settings-row-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"></path><polyline points="16 6 12 2 8 6"></polyline><line x1="12" y1="2" x2="12" y2="15"></line></svg></span>
              <div class="settings-row-body">
                <div class="settings-row-label">Akses Cepat (iOS)</div>
                <div class="settings-row-desc" style="white-space: normal; line-height: 1.4; margin-top: var(--sp-1);">
                  Dapatkan pengalaman aplikasi penuh secara offline. Ketuk ikon <strong>Share</strong> (Kirim) di bagian bawah Safari, gulir ke bawah, lalu pilih <strong>Add to Home Screen</strong>.
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="settings-section">
          <p class="settings-section-label">Data</p>
          <div class="settings-list">
            <div class="settings-row" style="cursor:pointer;" id="btn-export-data">
              <span class="settings-row-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg></span>
              <div class="settings-row-body settings-row-btn">
                <div class="settings-row-label">Ekspor Data</div>
                <div class="settings-row-desc">Unduh semua data sebagai JSON</div>
              </div>
              <span class="settings-chevron">&#8250;</span>
            </div>
            <div class="settings-row" style="cursor:pointer;" id="btn-clear-all-data">
              <span class="settings-row-icon" style="background: var(--danger-light); color: var(--danger);"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4a1 1 0 011-1h4a1 1 0 011 1v2"/></svg></span>
              <div class="settings-row-body">
                <button class="btn-danger-text">Hapus Semua Data</button>
                <div class="settings-row-desc">Tidak dapat dibatalkan</div>
              </div>
            </div>
          </div>
        </div>

        <p style="text-align:center;font-size:0.74rem;color:var(--text-3);padding:var(--sp-6) 0 0;">
          Bumpbuddy &bull; v3.0<br>
          Built by ❤️ for every expecting mothers
        </p>
      </div>
    </section>

  </main>

  <!-- TOAST -->
  <div id="toast-container" aria-live="polite"></div>

  <!-- CRITICAL ALERT OVERLAY -->
  <div class="alert-critical-overlay hidden" id="critical-overlay" role="alertdialog" aria-modal="true">
    <div class="alert-critical-modal">
      <div class="critical-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
      </div>
      <h2 class="critical-title">Waktunya ke RS!</h2>
      <p class="critical-message">Kontraksi sudah teratur dan kuat. Segera hubungi dokter atau pergi ke rumah sakit.</p>
      <div class="critical-stats">
        <div class="critical-stat"><span class="critical-stat-value" id="crit-count">--</span><span class="critical-stat-label">Kontraksi</span></div>
        <div class="critical-stat"><span class="critical-stat-value" id="crit-interval">--</span><span class="critical-stat-label">Interval</span></div>
        <div class="critical-stat"><span class="critical-stat-value" id="crit-duration">--</span><span class="critical-stat-label">Durasi Rata</span></div>
      </div>
      <div class="critical-actions">
        <a href="tel:119" class="btn-emergency" id="crit-ambulance-btn">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="width:18px;height:18px;"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.09 9.81a19.79 19.79 0 01-3.07-8.67A2 2 0 012 .84h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.91 8.84a16 16 0 006.29 6.29l1.28-1.28a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7a2 2 0 011.72 2.02z"/></svg>
          Panggil Ambulans (119)
        </a>
        <a href="#" class="btn-contact" id="crit-partner-btn">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:16px;height:16px;"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.09 9.81a19.79 19.79 0 01-3.07-8.67A2 2 0 012 .84h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.91 8.84a16 16 0 006.29 6.29l1.28-1.28a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7a2 2 0 011.72 2.02z"/></svg>
          Hubungi Pendamping
        </a>
        <a href="#" class="btn-contact" id="crit-doctor-btn">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:16px;height:16px;"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
          WhatsApp Dokter
        </a>
      </div>
      <button class="btn-dismiss-critical" id="btn-dismiss-critical">Tutup (sedang tidak bisa ke RS)</button>
    </div>
  </div>

  <!-- BOTTOM NAVIGATION -->
  <nav class="bottom-nav" id="tab-nav">
    <button class="tab-btn active" data-tab="contractions">
      <span class="tab-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
      </span>
      <span>Kontraksi</span>
    </button>
    <button class="tab-btn" data-tab="movements">
      <span class="tab-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12h.01"/><path d="M15 12h.01"/><path d="M10 16c.5.3 1.2.5 2 .5s1.5-.2 2-.5"/><path d="M19 6.3a9 9 0 0 1 1.8 3.9 2 2 0 0 1 0 3.6 9 9 0 0 1-17.6 0 2 2 0 0 1 0-3.6A9 9 0 0 1 12 3c2 0 3.5 1.1 3.5 2.5s-.9 2.5-2 2.5c-.8 0-1.5-.4-1.5-1"/></svg>
      </span>
      <span>Gerakan</span>
    </button>
    <button class="tab-btn" data-tab="symptoms">
      <span class="tab-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
      </span>
      <span>Gejala</span>
    </button>
    <button class="tab-btn" data-tab="bag">
      <span class="tab-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
      </span>
      <span>Tas RS</span>
    </button>
    <button class="tab-btn" data-tab="settings">
      <span class="tab-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
      </span>
      <span>Pengaturan</span>
    </button>
  </nav>

</div><!-- /#app -->

<!-- ONBOARDING OVERLAY -->
<div id="onboarding-overlay" class="onboarding-overlay hidden" role="dialog" aria-modal="true">
  <div class="onboarding-container">
    <div class="onboarding-double-bezel stagger-item stagger-1">
      <div class="onboarding-inner">
        <div class="onboarding-header stagger-item stagger-2">
          <div class="onboarding-logo-mark">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          </div>
          <h1 class="onboarding-title">Selamat datang</h1>
          <p class="onboarding-subtitle">Mari siapkan pendamping kehamilanmu.</p>
        </div>

        <div class="onboarding-field stagger-item stagger-3">
          <label class="onboarding-label" for="onboard-due-date">Hari Perkiraan Lahir</label>
          <input type="date" id="onboard-due-date" class="onboarding-input" required>
        </div>

        <div class="onboarding-field stagger-item stagger-4">
          <label class="onboarding-label" for="onboard-mother-name">Nama Ibu</label>
          <input type="text" id="onboard-mother-name" class="onboarding-input" placeholder="Nama panggilanmu..." required>
        </div>

        <div class="onboarding-field stagger-item stagger-5">
          <label class="onboarding-label" for="onboard-baby-name">Nama Panggilan Bayi</label>
          <input type="text" id="onboard-baby-name" class="onboarding-input" placeholder="Panggilan bayi...">
        </div>

        <div class="onboarding-field stagger-item stagger-6">
          <label class="onboarding-label">Gender Bayi</label>
          <div class="onboarding-gender-switch">
            <div class="gender-option selected" data-ob-gender="girl">Perempuan</div>
            <div class="gender-option" data-ob-gender="boy">Laki-laki</div>
          </div>
        </div>

        <button id="btn-finish-onboarding" class="btn btn-primary stagger-item stagger-6" style="width:100%;margin-top:var(--sp-5);">
          Mulai Sekarang
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  if ('serviceWorker' in navigator) {
    window.addEventListener('load', () => {
      navigator.serviceWorker.register('./sw.js')
        .then(r => console.log('[SW] registered', r.scope))
        .catch(e => console.warn('[SW] failed:', e));
    });
  }
</script>
<script src="app.js"></script>
</body>
</html>
